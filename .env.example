# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME="Miza Analytics"
APP_VERSION="1.0.0"
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://miza:miza@localhost:5432/miza_analytics
POSTGRES_USER=miza
POSTGRES_PASSWORD=miza
POSTGRES_DB=miza_analytics

# Connection pool (tune for expected concurrency)
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT=30

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=30

# ─── API Keys ──────────────────────────────────────────────────────────────────
# Format: comma-separated "client_id:sha256(raw_key)" pairs
# Generate a hash:
#   python3 -c "import hashlib; print(hashlib.sha256(b'YOUR_SECRET_KEY').hexdigest())"
# Then set: API_KEYS=your_client_id:<hash>
API_KEYS=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Batch Processing ──────────────────────────────────────────────────────────
MAX_BATCH_SIZE=100
